{
  "id": 15,
  "title": "قرآن در تابستان (یادآوری و روان‌خوانی)",
  "sessions": [
    {
      "type": "reading",
      "title": "بخش اول: سوره نبأ (آیات ۳۱ تا ۴۰)",
      "verses": [
        {
          "id": "78:31",
          "text_arabic": "إِنَّ لِلْمُتَّقِينَ مَفَازًا",
          "text_persian": "مسلماً برای پرهیزگاران نجات و رستگاری است،",
          "audio_url": "https://tanzil.net/res/audio/afasy/078031.mp3"
        },
        {
          "id": "78:32",
          "text_arabic": "حَدَائِقَ وَأَعْنَابًا",
          "text_persian": "باغ‌هایی سرسبز، و انواع انگورها،",
          "audio_url": "https://tanzil.net/res/audio/afasy/078032.mp3"
        },
        {
          "id": "78:33",
          "text_arabic": "وَكَوَاعِبَ أَتْرَابًا",
          "text_persian": "و حوریانی بسیار جوان و هم‌سن و سال،",
          "audio_url": "https://tanzil.net/res/audio/afasy/078033.mp3"
        },
        {
          "id": "78:34",
          "text_arabic": "وَكَأْسًا دِهَاقًا",
          "text_persian": "و جام‌هایی لبریز و پیاپی!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078034.mp3"
        },
        {
          "id": "78:35",
          "text_arabic": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّابًا",
          "text_persian": "در آنجا نه سخن لغو و بیهوده‌ای می‌شنوند و نه دروغی!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078035.mp3"
        },
        {
          "id": "78:36",
          "text_arabic": "جَزَاءً مِّن رَّبِّكَ عَطَاءً حِسَابًا",
          "text_persian": "این کیفری است از سوی پروردگارت و عطیه‌ای است کافی!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078036.mp3"
        },
        {
          "id": "78:37",
          "text_arabic": "رَّبِّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا الرَّحْمَٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا",
          "text_persian": "همان پروردگار آسمان‌ها و زمین و آنچه در میان آن دو است، پروردگار رحمان! و هیچ کس حق ندارد بی‌اجازه او سخنی بگوید!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078037.mp3"
        },
        {
          "id": "78:38",
          "text_arabic": "يَوْمَ يَقُومُ الرُّوحُ وَالْمَلَائِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ الرَّحْمَٰنُ وَقَالَ صَوَابًا",
          "text_persian": "روزی که «روح» و «فرشتگان» در یک صف می‌ایستند و هیچ یک، جز به اذن خداوند رحمان، سخن نمی‌گویند، و درست می‌گویند!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078038.mp3"
        },
        {
          "id": "78:39",
          "text_arabic": "ذَٰلِكَ الْيَوْمُ الْحَقُّ ۖ فَمَن شَاءَ اتَّخَذَ إِلَىٰ رَبِّهِ مَآبًا",
          "text_persian": "آن روز، روز حق است؛ پس هر کس بخواهد، راهی به سوی پروردگارش برمی‌گزیند!",
          "audio_url": "https://tanzil.net/res/audio/afasy/078039.mp3"
        },
        {
          "id": "78:40",
          "text_arabic": "إِنَّا أَنذَرْنَاكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ الْكَافِرُ يَا لَيْتَنِي كُنتُ تُرَابًا",
          "text_persian": "و ما شما را از عذاب نزدیکی بیم دادیم! در روزی که انسان آنچه را از قبل فرستاده می‌بیند، و کافر می‌گوید: «ای کاش خاک بودم!»",
          "audio_url": "https://tanzil.net/res/audio/afasy/078040.mp3"
        }
      ]
    },
    {
      "type": "reading",
      "title": "بخش دوم: سوره عبس (آیات ۳۳ تا ۴۲)",
      "verses": [
        {
          "id": "80:33",
          "text_arabic": "فَإِذَا جَاءَتِ الصَّاخَّةُ",
          "text_persian": "هنگامی که آن صدای مهیب (صیحه رستاخیز) بیاید،",
          "audio_url": "https://tanzil.net/res/audio/afasy/080033.mp3"
        },
        {
          "id": "80:34",
          "text_arabic": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
          "text_persian": "در آن روز که انسان از برادرش می‌گریزد،",
          "audio_url": "https://tanzil.net/res/audio/afasy/080034.mp3"
        },
        {
          "id": "80:35",
          "text_arabic": "وَأُمِّهِ وَأَبِيهِ",
          "text_persian": "و از مادر و پدرش،",
          "audio_url": "https://tanzil.net/res/audio/afasy/080035.mp3"
        },
        {
          "id": "80:36",
          "text_arabic": "وَصَاحِبَتِهِ وَبَنِيهِ",
          "text_persian": "و همسر و فرزندانش؛",
          "audio_url": "https://tanzil.net/res/audio/afasy/080036.mp3"
        },
        {
          "id": "80:37",
          "text_arabic": "لِكُلِّ امْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
          "text_persian": "در آن روز هر کدام از آنها وضعی دارد که او را کاملاً به خود مشغول می‌سازد!",
          "audio_url": "https://tanzil.net/res/audio/afasy/080037.mp3"
        },
        {
          "id": "80:38",
          "text_arabic": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
          "text_persian": "چهره‌هایی در آن روز گشاده و نورانی است،",
          "audio_url": "https://tanzil.net/res/audio/afasy/080038.mp3"
        },
        {
          "id": "80:39",
          "text_arabic": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
          "text_persian": "خندان و مسرور است؛",
          "audio_url": "https://tanzil.net/res/audio/afasy/080039.mp3"
        },
        {
          "id": "80:40",
          "text_arabic": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
          "text_persian": "و صورت‌هایی در آن روز غبارآلود است،",
          "audio_url": "https://tanzil.net/res/audio/afasy/080040.mp3"
        },
        {
          "id": "80:41",
          "text_arabic": "تَرْهَقُهَا قَتَرَةٌ",
          "text_persian": "و دود تاریکی آنها را پوشانده است؛",
          "audio_url": "https://tanzil.net/res/audio/afasy/080041.mp3"
        },
        {
          "id": "80:42",
          "text_arabic": "أُولَٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
          "text_persian": "آنان همان کافران فاجرند!",
          "audio_url": "https://tanzil.net/res/audio/afasy/080042.mp3"
        }
      ]
    },
    {
      "type": "reading",
      "title": "بخش سوم: سوره غاشیه (آیات ۱ تا ۲۶)",
      "verses": [
        {
          "id": "88:1",
          "text_arabic": "هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
          "text_persian": "آیا خبر آن حادثه فراگیر (= قیامت) به تو رسیده است؟",
          "audio_url": "https://tanzil.net/res/audio/afasy/088001.mp3"
        },
        {
          "id": "88:2",
          "text_arabic": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ",
          "text_persian": "در آن روز چهره‌هایی زبون و درهم کشیده‌اند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088002.mp3"
        },
        {
          "id": "88:3",
          "text_arabic": "عَامِلَةٌ نَّاصِبَةٌ",
          "text_persian": "پیوسته عمل کرده و خسته شده‌اند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088003.mp3"
        },
        {
          "id": "88:4",
          "text_arabic": "تَصْلَىٰ نَارًا حَامِيَةً",
          "text_persian": "در آتشی سوزان وارد می‌گردند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088004.mp3"
        },
        {
          "id": "88:5",
          "text_arabic": "تُسْقَىٰ مِنْ عَيْنٍ آنِيَةٍ",
          "text_persian": "از چشمه‌ای فوق‌العاده داغ به آنان می‌نوشانند.",
          "audio_url": "https://tanzil.net/res/audio/afasy/088005.mp3"
        },
        {
          "id": "88:6",
          "text_arabic": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
          "text_persian": "غذایی جز از خار خشک تلخ و بدبو ندارند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088006.mp3"
        },
        {
          "id": "88:7",
          "text_arabic": "لَّا يُسْمِنُ وَلَا يُغْنِي مِن جُوعٍ",
          "text_persian": "که نه آنان را فربه می‌کند و نه از گرسنگی می‌رهاند.",
          "audio_url": "https://tanzil.net/res/audio/afasy/088007.mp3"
        },
        {
          "id": "88:8",
          "text_arabic": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
          "text_persian": "چهره‌هایی در آن روز شاداب و باطراوت‌اند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088008.mp3"
        },
        {
          "id": "88:9",
          "text_arabic": "لِّسَعْيِهَا رَاضِيَةٌ",
          "text_persian": "و از سعی و تلاش خود خشنودند،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088009.mp3"
        },
        {
          "id": "88:10",
          "text_arabic": "فِي جَنَّةٍ عَالِيَةٍ",
          "text_persian": "در بهشتی عالی جای دارند.",
          "audio_url": "https://tanzil.net/res/audio/afasy/088010.mp3"
        },
        {
          "id": "88:11",
          "text_arabic": "لَّا تَسْمَعُ فِيهَا لَاغِيَةً",
          "text_persian": "هیچ سخن لغوی در آنجا نمی‌شنوی،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088011.mp3"
        },
        {
          "id": "88:12",
          "text_arabic": "فِيهَا عَيْنٌ جَارِيَةٌ",
          "text_persian": "در آن چشمه‌ای روان است،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088012.mp3"
        },
        {
          "id": "88:13",
          "text_arabic": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
          "text_persian": "در آن تخت‌های زیبای بلندی است،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088013.mp3"
        },
        {
          "id": "88:14",
          "text_arabic": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
          "text_persian": "و قدح‌هایی که نهاده شده،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088014.mp3"
        },
        {
          "id": "88:15",
          "text_arabic": "وَنَمَارِقُ مَصْفُوفَةٌ",
          "text_persian": "و بالش‌ها و پشتی‌های صف‌داده‌شده،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088015.mp3"
        },
        {
          "id": "88:16",
          "text_arabic": "وَزَرَابِيُّ مَبْثُوثَةٌ",
          "text_persian": "و فرش‌های فاخر گسترده!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088016.mp3"
        },
        {
          "id": "88:17",
          "text_arabic": "أَفَلَا يَنظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ",
          "text_persian": "آیا آنان به شتر نمی‌نگرند که چگونه آفریده شده است؟!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088017.mp3"
        },
        {
          "id": "88:18",
          "text_arabic": "وَإِلَى السَّمَاءِ كَيْفَ رُفِعَتْ",
          "text_persian": "و به آسمان که چگونه برافراشته شده است؟!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088018.mp3"
        },
        {
          "id": "88:19",
          "text_arabic": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ",
          "text_persian": "و به کوه‌ها که چگونه استوار و پابرجا نصب شده است؟!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088019.mp3"
        },
        {
          "id": "88:20",
          "text_arabic": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ",
          "text_persian": "و به زمین که چگونه گسترده و هموار گشته است؟!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088020.mp3"
        },
        {
          "id": "88:21",
          "text_arabic": "فَذَكِّرْ إِنَّمَا أَنتَ مُذَكِّرٌ",
          "text_persian": "پس تذکّر ده که تو فقط تذکّر دهنده‌ای!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088021.mp3"
        },
        {
          "id": "88:22",
          "text_arabic": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
          "text_persian": "تو بر آنان تسلّطی نداری که مجبورشان کنی،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088022.mp3"
        },
        {
          "id": "88:23",
          "text_arabic": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
          "text_persian": "مگر کسی که روی‌گردان شود و کفر ورزد،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088023.mp3"
        },
        {
          "id": "88:24",
          "text_arabic": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ",
          "text_persian": "که خداوند او را به عذاب بزرگ مجازات می‌کند!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088024.mp3"
        },
        {
          "id": "88:25",
          "text_arabic": "إِنَّ إِلَيْنَا إِيَابَهُمْ",
          "text_persian": "به یقین بازگشت آنان به سوی ماست،",
          "audio_url": "https://tanzil.net/res/audio/afasy/088025.mp3"
        },
        {
          "id": "88:26",
          "text_arabic": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
          "text_persian": "و سپس حسابشان (نیز) بر ماست!",
          "audio_url": "https://tanzil.net/res/audio/afasy/088026.mp3"
        }
      ]
    },
    {
      "type": "reading",
      "title": "بخش چهارم: سوره اعلی (آیات ۱ تا ۱۹)",
      "verses": [
        {
          "id": "87:1",
          "text_arabic": "سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى",
          "text_persian": "منزّه شمار نام پروردگار بلندمرتبه‌ات را!",
          "audio_url": "https://tanzil.net/res/audio/afasy/087001.mp3"
        },
        {
          "id": "87:2",
          "text_arabic": "الَّذِي خَلَقَ فَسَوَّىٰ",
          "text_persian": "همان خداوندی که آفرید و منظّم کرد،",
          "audio_url": "https://tanzil.net/res/audio/afasy/087002.mp3"
        },
        {
          "id": "87:3",
          "text_arabic": "وَالَّذِي قَدَّرَ فَهَدَىٰ",
          "text_persian": "و همان که اندازه‌گیری کرد و هدایت نمود،",
          "audio_url": "https://tanzil.net/res/audio/afasy/087003.mp3"
        },
        {
          "id": "87:4",
          "text_arabic": "وَالَّذِي أَخْرَجَ الْمَرْعَىٰ",
          "text_persian": "و آن کس که چراگاه را به وجود آورد،",
          "audio_url": "https://tanzil.net/res/audio/afasy/087004.mp3"
        },
        {
          "id": "87:5",
          "text_arabic": "فَجَعَلَهُ غُثَاءً أَحْوَىٰ",
          "text_persian": "سپس آن را خشک و تیره قرار داد!",
          "audio_url": "https://tanzil.net/res/audio/afasy/087005.mp3"
        },
        {
          "id": "87:6",
          "text_arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰ",
          "text_persian": "ما بزودی بر تو می‌خوانیم تا فراموش نکنی،",
          "audio_url": "https://tanzil.net/res/audio/afasy/087006.mp3"
        },
        {
          "id": "87:7",
          "text_arabic": "إِلَّا مَا شَاءَ اللَّهُ ۚ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ",
          "text_persian": "مگر آنچه را خدا بخواهد، که او آشکار و پنهان را می‌داند!",
          "audio_url": "https://tanzil.net/res/audio/afasy/087007.mp3"
        },
        {
          "id": "87:8",
          "text_arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
          "text_persian": "و ما تو را برای انجام هر کار خیری توفیق می‌دهیم!",
          "audio_url": "https://tanzil.net/res/audio/afasy/087008.mp3"
        },
        {
          "id": "87:9",
